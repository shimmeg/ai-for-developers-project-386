# Copy to backend/.env. The backend auto-loads this file on startup;
# real process env vars always win when both are set.
PORT=3000
# Optional. If set, must be ≥16 characters; generate with: openssl rand -hex 24.
# If unset, the server generates a random token at startup and admin endpoints
# become inaccessible (handy for CI smoke checks of the public catalog).
ADMIN_TOKEN=please-change-me-to-a-long-random-string
FRONTEND_ORIGIN=http://localhost:5173
DEFAULT_TZ=UTC
LOG_LEVEL=info
