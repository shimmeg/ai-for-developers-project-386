{
  "name": "calendar-service-contract",
  "version": "0.1.0",
  "description": "API contract (TypeSpec → OpenAPI 3.1) for the calendar booking service.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsp compile .",
    "test": "npm run build && node --test tests/*.test.mjs",
    "watch": "tsp compile . --watch",
    "format": "tsp format \"**/*.tsp\"",
    "clean": "rm -rf tsp-output"
  },
  "dependencies": {
    "@typespec/compiler": "^1.11.0",
    "@typespec/http": "^1.11.0",
    "@typespec/rest": "^0.81.0",
    "@typespec/openapi": "^1.11.0",
    "@typespec/openapi3": "^1.11.0"
  },
  "devDependencies": {
    "yaml": "^2.8.4"
  }
}
