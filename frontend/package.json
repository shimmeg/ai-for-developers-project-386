{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently -n contract,mock,vite -c blue,green,magenta \"npm:contract:watch\" \"npm:mock\" \"npm:dev\"",
    "contract:build": "npm --prefix ../contract run build",
    "contract:watch": "npm --prefix ../contract run watch",
    "mock": "prism mock ../contract/tsp-output/@typespec/openapi3/openapi.yaml -p 4010 --cors",
    "gen:api": "npm run contract:build && openapi-typescript ../contract/tsp-output/@typespec/openapi3/openapi.yaml -o src/api/types.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "overrides": {
    "http-proxy-agent": "^7.0.2",
    "postman-collection": {
      "lodash": "^4.18.1"
    }
  },
  "dependencies": {
    "@mantine/core": "^9.1.1",
    "@mantine/dates": "^9.1.1",
    "@mantine/form": "^9.1.1",
    "@mantine/hooks": "^9.1.1",
    "@mantine/notifications": "^9.1.1",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-query": "^5.100.9",
    "mantine-form-zod-resolver": "^1.3.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router": "^7.15.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stoplight/prism-cli": "^5.15.10",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.1",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.5.0",
    "typescript": "~5.7.0",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
